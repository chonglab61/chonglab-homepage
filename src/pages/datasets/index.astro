---
import Layout from '../../components/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { datasets } from '../../data/site';
import '../../styles/global.css';
---

<Layout title="Datasets | Chong Lab" description="Open dataset index for Chong Lab.">
  <section class="page-intro">
    <SectionHeading
      eyebrow="Datasets"
      title="Open datasets preserved as links, not duplicated payloads"
      summary="This keeps the static site small while still surfacing the lab's downloadable assets."
    />
  </section>

  <section class="section">
    <div class="grid grid--cards">
      {datasets.map((group) => (
        <article class="card">
          <div class="card__body">
            <p class="card__kicker">Dataset group</p>
            <h3>{group.title}</h3>
            <p>{group.description}</p>
            <div class="chips">
              {group.links.map((link) => (
                <a class="chip" href={`${group.baseUrl}/${link}`} target="_blank" rel="noopener noreferrer">
                  {link}
                </a>
              ))}
            </div>
            <a class="card__link" href={group.baseUrl} target="_blank" rel="noopener noreferrer">Download / View on JAIST →</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
