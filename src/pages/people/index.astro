---
import Layout from '../../components/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import PersonCard from '../../components/PersonCard.astro';
import { people } from '../../data/site';
import '../../styles/global.css';
---

<Layout title="People | Chong Lab" description="Chong Lab director and teaching assistants.">
  <section class="page-intro">
    <SectionHeading
      eyebrow="People"
      title="Director and teaching assistants only"
      summary="This static site intentionally limits people content to the director and teaching assistants."
    />
  </section>

  <section class="section">
    <div class="intro-grid intro-grid--people">
      <div class="intro-grid__media">
        <img src={people.director.photo} alt={people.director.name} width="400" height="400" loading="lazy" />
      </div>
      <div class="intro-grid__body">
        <p class="card__kicker">Director</p>
        <h3>{people.director.name}</h3>
        <p>{people.director.title}</p>
        <p>{people.director.office}</p>
        <p>TEL {people.director.tel}, FAX {people.director.fax}</p>
        <p>Email {people.director.email}</p>
        <a class="card__link" href={people.director.jaist_profile_url} target="_blank" rel="noopener noreferrer">Full Profile on JAIST →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Teaching Assistants" title="Current assistants" />
    <div class="grid grid--people">
      {people.assistants.map((person) => <PersonCard person={person} kind="student" />)}
    </div>
    <p class="section__cta"><a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">For full member list, visit the JAIST lab page →</a></p>
  </section>
</Layout>
