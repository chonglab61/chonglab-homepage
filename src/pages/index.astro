---
import Layout from '../components/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { hero, highlights, introduction } from '../data/site';
import '../styles/global.css';
---

<Layout title="Chong Lab" description="JAIST Chong Lab static front door and research index.">
  <section class="hero">
    <div class="hero__content">
      <p class="hero__eyebrow">{hero.eyebrow}</p>
      <h1>{hero.title}</h1>
      <p>{hero.description}</p>
      <div class="hero__actions">
        <a class="button button--primary" href={hero.primaryCta.href}>{hero.primaryCta.label}</a>
        <a class="button" href={hero.secondaryCta.href}>{hero.secondaryCta.label}</a>
      </div>
    </div>

    <aside class="hero__panel">
      <SectionHeading eyebrow="Deployment" title="Cloudflare-ready and intentionally small" />
      <div class="hero__stats">
        {highlights.map((item) => (
          <div class="stat">
            <strong>{item.label}</strong>
            <span>{item.value}</span>
          </div>
        ))}
      </div>
    </aside>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Research Areas" title="Find more research area here" summary="CV Area, Emotion Detection, Caresses, and related projects." />
    <div class="chips">
      <span class="chip">Robot-Assisted Ultrasound Imaging</span>
      <span class="chip">Nonprehensile Manipulation</span>
      <span class="chip">Swarm Robotics</span>
      <span class="chip">RFID</span>
      <span class="chip">JARoW</span>
      <span class="chip">Humanoid Robotics</span>
      <span class="chip">UAV</span>
      <span class="chip">Incremental Learning</span>
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Introduction"
      title="Robotics Laboratory"
      summary={introduction.summary}
    />
    <div class="page-essay">
      <div class="list-grid">
        <div class="list-item">
          <strong>Director</strong>
          <p>{introduction.director.name}</p>
          <p>{introduction.director.role}</p>
          <p>{introduction.director.contact}</p>
          <p>{introduction.director.office}</p>
          <p>TEL {introduction.director.phone}, FAX {introduction.director.fax}</p>
          <p>Email {introduction.director.email}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Professional Service"
      title="Academic service and visiting appointments"
      summary="A concise version of the service history from the original lab introduction."
    />
    <div class="list-grid">
      {introduction.service.map((item) => (
        <div class="list-item">{item}</div>
      ))}
    </div>
  </section>
</Layout>
