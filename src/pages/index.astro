---
import Layout from '../components/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { hero, researchAreas, serviceTiles, introduction } from '../data/site';
import '../styles/global.css';
---

<Layout title="Chong Lab | Intelligent Robotic Laboratory of JAIST" description="JAIST Chong Lab static front door and research index.">
  <section class="hero" id="main">
    <canvas class="hero__canvas" id="hero-canvas" aria-hidden="true"></canvas>
    <div class="hero__content">
      <p class="hero__eyebrow">{hero.eyebrow}</p>
      <h1>{hero.title}</h1>
      <p>{hero.description}</p>
      <div class="hero__actions">
        <a class="button button--primary" href={hero.primaryCta.href}>{hero.primaryCta.label}</a>
        <a class="button" href={hero.secondaryCta.href} target="_blank" rel="noopener noreferrer">{hero.secondaryCta.label}</a>
      </div>
    </div>
    <a class="hero__chevron" href="#research-areas" aria-label="Scroll to the next section">↓</a>
  </section>

  <section class="section" id="research-areas">
    <SectionHeading eyebrow="Research Areas" title="Find more research areas here" summary="Research summaries that point either to the internal index or the original JAIST pages." />
    <div class="grid grid--cards">
      {researchAreas.map((area) => (
        <article class="card">
          <div class="card__body">
            <p class="card__kicker">Theme</p>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
            {area.href.startsWith('http') ? (
              <a class="card__link" href={area.href} target="_blank" rel="noopener noreferrer">Explore →</a>
            ) : (
              <a class="card__link" href={area.href}>Explore →</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Lab Services" title="Quick access for members and visitors" summary="Links to the original JAIST site stay external, while public static pages stay local." />
    <div class="grid grid--services">
      {serviceTiles.map((tile) => (
        <article class="card card--service">
          <div class="card__body">
            <p class="card__kicker">{tile.icon}</p>
            <h3>{tile.label}</h3>
            <p>{tile.description}</p>
            {tile.locked ? <p class="card__badge">Requires JAIST account</p> : null}
            <a class="card__link" href={tile.href} target={tile.external ? '_blank' : undefined} rel={tile.external ? 'noopener noreferrer' : undefined}>Open →</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Introduction" title="Director introduction" summary={introduction.summary} />
    <div class="intro-grid">
      <div class="intro-grid__media">
        <img src={introduction.director.photo} alt="Prof. Nak Young Chong" width="400" height="400" loading="lazy" />
      </div>
      <div class="intro-grid__body">
        <p class="card__kicker">Director</p>
        <h3>{introduction.director.name}</h3>
        <p>{introduction.director.title}</p>
        <p>{introduction.director.office}</p>
        <p>TEL {introduction.director.phone}, FAX {introduction.director.fax}</p>
        <p>Email {introduction.director.email}</p>
        <a class="card__link" href={introduction.director.jaist_profile_url} target="_blank" rel="noopener noreferrer">Full Profile on JAIST →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Professional Service" title="Academic service and visiting appointments" summary="A condensed record of the service history from the original lab introduction." />
    <div class="list-grid">
      {introduction.service.map((item) => <div class="list-item">{item}</div>)}
    </div>
    <p class="section__cta"><a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">View full academic record →</a></p>
  </section>
</Layout>
