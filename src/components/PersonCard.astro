---
const { person, kind } = Astro.props;
---

<article class={`card card--person ${kind === 'staff' ? 'card--staff' : ''}`}>
  <div class="card__body">
    <p class="card__kicker">{person.role}</p>
    <h3>{person.name}</h3>
    {person.title ? <p class="card__meta">{person.title}</p> : null}
    {person.email ? <p class="card__meta">{person.email}</p> : null}
    {person.note ? <p>{person.note}</p> : null}
    {person.href ? <a class="card__link" href={person.href} target="_blank" rel="noopener noreferrer">View profile →</a> : null}
  </div>
</article>
