---
import { getCopy } from '../i18n/copy';
import { localizedPath } from '../lib/i18n';

const { locale = 'en' } = Astro.props;
const copy = getCopy(locale);
---

<footer class="footer">
  <div>
    <strong>{copy.footer.brand}</strong>
    <p>{copy.footer.subtitle}</p>
    <p>{copy.footer.address}</p>
    <p>{copy.footer.email}</p>
  </div>
  <div>
    <p>{copy.footer.quickLinks}</p>
    <p><a href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{copy.footer.original}</a></p>
    <p><a href={localizedPath(locale, '/research/')}>{copy.footer.research}</a></p>
    <p><a href={localizedPath(locale, '/datasets/')}>{copy.footer.datasets}</a></p>
    <p><a href="https://github.com/chonglab61" target="_blank" rel="noopener noreferrer">{copy.footer.github}</a></p>
  </div>
  <div>
    <p>{copy.footer.copyright}</p>
  </div>
</footer>
