---
import Layout from './Layout.astro';
import SectionHeading from './SectionHeading.astro';
import ResearchCard from './ResearchCard.astro';
import PersonCard from './PersonCard.astro';
import { getCopy } from '../i18n/copy';
import { localizedPath } from '../lib/i18n';

const { locale = 'en', page = 'home' } = Astro.props;
const copy = getCopy(locale);
const pageCopy = copy[page];
const directorProfile =
  locale === 'ja' ? '情報科学系 教授, JAIST' : locale === 'zh' ? 'JAIST 信息科学系 教授' : 'Professor, School of Information Science, JAIST';
const sectionSuffix = copy.ui;
---

<Layout locale={locale} title={pageCopy.metaTitle} description={pageCopy.metaDescription}>
  {page === 'home' && (
    <>
      <section class="hero" id="main">
        <canvas class="hero__canvas" id="hero-canvas" aria-hidden="true"></canvas>
        <div class="hero__content">
          <p class="hero__eyebrow">{pageCopy.hero.eyebrow}</p>
          <h1>{pageCopy.hero.title}</h1>
          <p>{pageCopy.hero.description}</p>
          <div class="hero__actions">
            <a class="button button--primary" href={localizedPath(locale, '/research/')}>{pageCopy.hero.primaryCta}</a>
            <a class="button" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.hero.secondaryCta}</a>
          </div>
        </div>
        <a class="hero__chevron" href="#research-areas" aria-label={sectionSuffix.scrollToNext}>↓</a>
      </section>

      <section class="section" id="research-areas">
        <SectionHeading eyebrow={pageCopy.researchSection.eyebrow} title={pageCopy.researchSection.title} summary={pageCopy.researchSection.summary} />
        <div class="grid grid--cards">
          {pageCopy.researchAreas.map((area, index) => (
            <article class="card">
              <div class="card__body">
                <p class="card__kicker">{sectionSuffix.themeCardLabel}</p>
                <h3>{area.title}</h3>
                <p>{area.description}</p>
                {index === 2 ? (
                  <a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{area.action}</a>
                ) : (
                  <a class="card__link" href={localizedPath(locale, '/research/')}>{area.action}</a>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <SectionHeading eyebrow={pageCopy.serviceSection.eyebrow} title={pageCopy.serviceSection.title} summary={pageCopy.serviceSection.summary} />
        <div class="grid grid--services">
          {pageCopy.serviceTiles.map((tile, index) => {
            const urls = [
              'https://www.jaist.ac.jp/robot/',
              'https://www.jaist.ac.jp/robot/research/',
              'https://www.jaist.ac.jp/robot/',
              localizedPath(locale, '/datasets/'),
              'https://github.com/chonglab61',
              'mailto:robot@ml.jaist.ac.jp'
            ];

            return (
              <article class="card card--service">
                <div class="card__body">
                  <p class="card__kicker">{['globe', 'flask', 'lock', 'database', 'brand-github', 'mail'][index]}</p>
                  <h3>{tile.label}</h3>
                  <p>{tile.description}</p>
                  {tile.locked ? <p class="card__badge">{sectionSuffix.requiresAccount}</p> : null}
                  <a class="card__link" href={urls[index]} target={index === 0 || index === 1 || index === 2 || index === 4 ? '_blank' : undefined} rel={index === 0 || index === 1 || index === 2 || index === 4 ? 'noopener noreferrer' : undefined}>{tile.action}</a>
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <section class="section">
        <SectionHeading eyebrow={pageCopy.introductionSection.eyebrow} title={pageCopy.introductionSection.title} summary={pageCopy.introductionSection.summary} />
        <div class="intro-grid">
          <div class="intro-grid__media">
            <img src="/assets/img/prof-chong.svg" alt="Prof. Nak Young Chong" width="400" height="400" loading="lazy" />
          </div>
          <div class="intro-grid__body">
            <p class="card__kicker">{pageCopy.introductionSection.directorLabel}</p>
            <h3>{locale === 'zh' ? 'Chong 教授，博士' : 'Nak Young Chong, Ph.D.'}</h3>
            <p>{directorProfile}</p>
            <p>{locale === 'zh' ? '石川县能美市旭台 1-1, 923-1292, 日本' : locale === 'ja' ? '〒923-1292 石川県能美市旭台1-1' : '1-1 Asahidai, Nomi, Ishikawa 923-1292, Japan'}</p>
            <p>{locale === 'ja' ? '研究室 6F IS Building 1, I-61' : locale === 'zh' ? '研究室 6F IS Building 1, I-61' : 'Office I-61, 6F IS Building 1'}</p>
            <p>TEL +81-761-51-1248, FAX +81-761-51-1149</p>
            <p>Email nakyoung@jaist.ac.jp</p>
            <a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.introductionSection.profileLabel}</a>
          </div>
        </div>
      </section>

      <section class="section">
        <SectionHeading eyebrow={pageCopy.serviceHistorySection.eyebrow} title={pageCopy.serviceHistorySection.title} summary={pageCopy.serviceHistorySection.summary} />
        <div class="list-grid">
          {pageCopy.serviceHistory.map((item) => <div class="list-item">{item}</div>)}
        </div>
        <p class="section__cta"><a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.serviceHistorySection.cta}</a></p>
      </section>
    </>
  )}

  {page === 'research' && (
    <>
      <section class="page-intro">
        <SectionHeading eyebrow={pageCopy.intro.eyebrow} title={pageCopy.intro.title} summary={pageCopy.intro.summary} />
      </section>

      <section class="section">
        <div class="grid grid--cards">
          {pageCopy.featuredResearch.map((item, index) => {
            const urls = [
              'https://www.jaist.ac.jp/robot/research/sg4hri/sg4hri.php',
              'https://www.jaist.ac.jp/robot/research/ultrasound/ultrasound.php',
              'https://www.jaist.ac.jp/robot/research/TEPP/TEPP.php',
              'https://www.jaist.ac.jp/robot/research/swarmrobot/swarmrobot.php'
            ];

            return <ResearchCard item={{ ...item, href: urls[index] }} />;
          })}
        </div>
      </section>

      <section class="section">
        <SectionHeading eyebrow={pageCopy.themes.eyebrow} title={pageCopy.themes.title} />
        <div class="grid grid--cards">
          {pageCopy.themesList.map((group) => (
            <article class="card">
              <div class="card__body">
                <p class="card__kicker">{sectionSuffix.themeCardLabel}</p>
                <h3>{group.title}</h3>
                <div class="list-grid">
                  {group.items.map((item) => <div class="list-item">{item}</div>)}
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="section__cta"><a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.themes.cta}</a></p>
      </section>
    </>
  )}

  {page === 'about' && (
      <section class="page-intro">
        <SectionHeading eyebrow={pageCopy.intro.eyebrow} title={pageCopy.intro.title} summary={pageCopy.intro.summary} />
        <div class="list-grid">
          <div class="list-item">
            <strong>{pageCopy.director.label}</strong>
            <p>{locale === 'zh' ? 'Chong 教授，博士' : 'Nak Young Chong, Ph.D.'}</p>
          <p>{locale === 'ja' ? '情報科学系 教授, JAIST' : locale === 'zh' ? 'JAIST 信息科学系 教授' : 'Professor, School of Information Science, JAIST'}</p>
          <p>{locale === 'zh' ? '石川县能美市旭台 1-1, 923-1292, 日本' : locale === 'ja' ? '〒923-1292 石川県能美市旭台1-1' : '1-1 Asahidai, Nomi, Ishikawa 923-1292, Japan'}</p>
          <p>{locale === 'ja' ? '研究室 6F IS Building 1, I-61' : 'Office I-61, 6F IS Building 1'}</p>
          <p>TEL +81-761-51-1248, FAX +81-761-51-1149</p>
          <p>Email nakyoung@jaist.ac.jp</p>
          <a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.director.profileLabel}</a>
        </div>
        {copy.en.home.serviceHistory.map((item) => (
          <div class="list-item">{item}</div>
        ))}
      </div>
    </section>
  )}

  {page === 'people' && (
    <>
      <section class="page-intro">
        <SectionHeading eyebrow={pageCopy.intro.eyebrow} title={pageCopy.intro.title} summary={pageCopy.intro.summary} />
      </section>

      <section class="section">
        <div class="intro-grid intro-grid--people">
          <div class="intro-grid__media">
            <img src="/assets/img/prof-chong.svg" alt="Prof. Nak Young Chong" width="400" height="400" loading="lazy" />
          </div>
          <div class="intro-grid__body">
            <p class="card__kicker">{pageCopy.director.label}</p>
            <h3>{locale === 'zh' ? 'Chong 教授，博士' : 'Nak Young Chong, Ph.D.'}</h3>
            <p>{locale === 'ja' ? '情報科学系 教授, JAIST' : locale === 'zh' ? 'JAIST 信息科学系 教授' : 'Professor, School of Information Science, JAIST'}</p>
            <p>{locale === 'zh' ? '石川县能美市旭台 1-1, 923-1292, 日本' : locale === 'ja' ? '〒923-1292 石川県能美市旭台1-1' : '1-1 Asahidai, Nomi, Ishikawa 923-1292, Japan'}</p>
            <p>{locale === 'ja' ? '研究室 6F IS Building 1, I-61' : 'Office I-61, 6F IS Building 1'}</p>
            <p>TEL +81-761-51-1248, FAX +81-761-51-1149</p>
            <p>Email nakyoung@jaist.ac.jp</p>
            <a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.director.profileLabel}</a>
          </div>
        </div>
      </section>

      <section class="section">
        <SectionHeading eyebrow={pageCopy.assistantsHeading} title={pageCopy.assistantsHeading} />
        <div class="grid grid--people">
          {pageCopy.assistants.map((person) => <PersonCard person={person} kind="student" />)}
        </div>
        <p class="section__cta"><a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.cta}</a></p>
      </section>
    </>
  )}

  {page === 'datasets' && (
    <>
      <section class="page-intro">
        <SectionHeading eyebrow={pageCopy.intro.eyebrow} title={pageCopy.intro.title} summary={pageCopy.intro.summary} />
      </section>

      <section class="section">
        <div class="grid grid--cards">
          {pageCopy.groups.map((group, index) => {
            const urls = [
              'https://www.jaist.ac.jp/robot/datasets/comb1',
              'https://www.jaist.ac.jp/robot/datasets/comb2',
              'https://www.jaist.ac.jp/robot/datasets/ellip',
              'https://www.jaist.ac.jp/robot/datasets/plg3'
            ];

            return (
              <article class="card">
                <div class="card__body">
                  <p class="card__kicker">{sectionSuffix.datasetGroup}</p>
                  <h3>{group.title}</h3>
                  <p>{group.description}</p>
                  <a class="card__link" href={urls[index]} target="_blank" rel="noopener noreferrer">{group.action}</a>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    </>
  )}
</Layout>
