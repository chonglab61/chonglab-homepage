---
import HomePage from './pages/HomePage.astro';
import ResearchPage from './pages/ResearchPage.astro';
import AboutPage from './pages/AboutPage.astro';
import PeoplePage from './pages/PeoplePage.astro';
import DatasetsPage from './pages/DatasetsPage.astro';

const { locale = 'en', page = 'home' } = Astro.props;

const ActivePage =
  page === 'research'
    ? ResearchPage
    : page === 'about'
      ? AboutPage
      : page === 'people'
        ? PeoplePage
        : page === 'datasets'
          ? DatasetsPage
          : HomePage;
---

<ActivePage locale={locale} />
