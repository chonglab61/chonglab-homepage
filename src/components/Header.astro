---
import { navItems } from '../data/site';
---

<header class="topbar" data-nav>
  <div class="topbar__brand">
    <a href="/" aria-label="Chong Lab home"><span class="topbar__dot" aria-hidden="true"></span>Chong Lab</a>
    <span>Intelligent Robotic Laboratory of JAIST</span>
  </div>

  <button class="topbar__toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
    Menu
  </button>

  <button class="topbar__theme" type="button" data-theme-toggle aria-label="Toggle theme">
    Theme: Auto
  </button>

  <nav class="topbar__nav" id="primary-nav" aria-label="Primary">
    {navItems.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>
