---
import SectionHeading from '../SectionHeading.astro';
import PersonCard from '../PersonCard.astro';
import { getCopy } from '../../i18n/copy';

const { locale = 'en' } = Astro.props;
const copy = getCopy(locale);
const pageCopy = copy.people;
---

<>
  <section class="page-intro">
    <SectionHeading eyebrow={pageCopy.intro.eyebrow} title={pageCopy.intro.title} summary={pageCopy.intro.summary} />
  </section>

  <section class="section">
    <div class="intro-grid intro-grid--people">
      <div class="intro-grid__media">
        <img src="/assets/img/prof-chong.svg" alt="Prof. Nak Young Chong" width="400" height="400" loading="lazy" />
      </div>
      <div class="intro-grid__body">
        <p class="card__kicker">{pageCopy.director.label}</p>
        <h3>{pageCopy.director.name}</h3>
        <p>{pageCopy.director.title}</p>
        <p>{pageCopy.director.address}</p>
        <p>{pageCopy.director.office}</p>
        <p>TEL +81-761-51-1248, FAX +81-761-51-1149</p>
        <p>Email nakyoung@jaist.ac.jp</p>
        <a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.director.profileLabel}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHeading eyebrow={pageCopy.assistantsHeading} title={pageCopy.assistantsHeading} />
    <div class="grid grid--people">
      {pageCopy.assistants.map((person) => <PersonCard person={person} kind="student" />)}
    </div>
    <p class="section__cta"><a class="card__link" href="https://www.jaist.ac.jp/robot/" target="_blank" rel="noopener noreferrer">{pageCopy.cta}</a></p>
  </section>
</>
